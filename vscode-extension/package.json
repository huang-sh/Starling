{
  "name": "starling-ai",
  "displayName": "Starling Agent",
  "description": "Agent session manager — discover, pin, and organize AI coding sessions",
  "version": "0.0.1",
  "publisher": "huangsh",
  "icon": "icons/starling.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huang-sh/Starling"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:starling-projects",
    "onView:starling-sessions",
    "onCommand:starling.refresh",
    "onCommand:starling.resume",
    "onCommand:starling.pin",
    "onCommand:starling.pinToSpace",
    "onCommand:starling.removePin",
    "onCommand:starling.deleteSession",
    "onCommand:starling.showSession",
    "onCommand:starling.sessionList",
    "onCommand:starling.sessionShow",
    "onCommand:starling.sessionIndexStatus",
    "onCommand:starling.sessionIndexRebuild",
    "onCommand:starling.sessionIndexClear",
    "onCommand:starling.loadMoreSessions",
    "onCommand:starling.loadMoreProjectSessions",
    "onCommand:starling.modelList",
    "onCommand:starling.copySessionId",
    "onCommand:starling.catalogList",
    "onCommand:starling.catalogTree",
    "onCommand:starling.catalogShow",
    "onCommand:starling.catalogCreate",
    "onCommand:starling.catalogRemove",
    "onCommand:starling.catalogTag",
    "onCommand:starling.catalogEdit",
    "onCommand:starling.projectList",
    "onCommand:starling.projectShow",
    "onCommand:starling.openProject",
    "onCommand:starling.copyProject"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "starling",
          "title": "Starling",
          "icon": "icons/starling_logo.svg"
        }
      ]
    },
    "views": {
      "starling": [
        {
          "id": "starling-spaces",
          "name": "Catalog",
          "icon": "$(layers)"
        },
        {
          "id": "starling-projects",
          "name": "Projects",
          "icon": "$(repo)"
        },
        {
          "id": "starling-sessions",
          "name": "Sessions",
          "icon": "$(server)"
        }
      ]
    },
    "commands": [
      {
        "command": "starling.refresh",
        "title": "Starling: Refresh"
      },
      {
        "command": "starling.resume",
        "title": "Starling: Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "starling.pin",
        "title": "Starling: Pin Session",
        "icon": "$(pin)"
      },
      {
        "command": "starling.pinToSpace",
        "title": "Starling: Pin to Catalog"
      },
      {
        "command": "starling.removePin",
        "title": "Starling: Remove Pin",
        "icon": "$(pinned-dirty)"
      },
      {
        "command": "starling.deleteSession",
        "title": "Starling: Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "starling.showSession",
        "title": "Starling: Show Session Details",
        "icon": "$(eye)"
      },
      {
        "command": "starling.sessionList",
        "title": "Starling: List Sessions"
      },
      {
        "command": "starling.sessionShow",
        "title": "Starling: Show Session"
      },
      {
        "command": "starling.sessionIndexStatus",
        "title": "Starling: Session Index Status"
      },
      {
        "command": "starling.sessionIndexRebuild",
        "title": "Starling: Rebuild Session Index"
      },
      {
        "command": "starling.sessionIndexClear",
        "title": "Starling: Clear Session Index"
      },
      {
        "command": "starling.loadMoreSessions",
        "title": "Starling: Load More Sessions"
      },
      {
        "command": "starling.loadMoreProjectSessions",
        "title": "Starling: Load More Project Sessions"
      },
      {
        "command": "starling.modelList",
        "title": "Starling: List Models"
      },
      {
        "command": "starling.catalogList",
        "title": "Starling: List Catalogs"
      },
      {
        "command": "starling.catalogTree",
        "title": "Starling: Catalog Tree"
      },
      {
        "command": "starling.catalogShow",
        "title": "Starling: Show Catalog"
      },
      {
        "command": "starling.catalogCreate",
        "title": "Starling: Create Catalog"
      },
      {
        "command": "starling.catalogRemove",
        "title": "Starling: Remove Catalog"
      },
      {
        "command": "starling.catalogTag",
        "title": "Starling: Tag Catalog"
      },
      {
        "command": "starling.catalogEdit",
        "title": "Starling: Edit Catalog"
      },
      {
        "command": "starling.projectList",
        "title": "Starling: List Projects"
      },
      {
        "command": "starling.projectShow",
        "title": "Starling: Show Project"
      },
      {
        "command": "starling.openProject",
        "title": "Starling: Open Project in New Window",
        "icon": "$(window)"
      },
      {
        "command": "starling.copyProject",
        "title": "Starling: Copy Project Path",
        "icon": "$(copy)"
      },
      {
        "command": "starling.copySessionId",
        "title": "Starling: Copy Session ID",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "starling.resume",
          "when": "viewItem =~ /session/ || viewItem =~ /pin/",
          "group": "inline@1"
        },
        {
          "command": "starling.showSession",
          "when": "viewItem =~ /session/",
          "group": "inline@2"
        },
        {
          "command": "starling.pin",
          "when": "viewItem =~ /session/ && viewItem =~ /unpinned/",
          "group": "inline@3"
        },
        {
          "command": "starling.pinToSpace",
          "when": "viewItem =~ /session/ || viewItem =~ /pin/",
          "group": "inline@4"
        },
        {
          "command": "starling.resume",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == session-pin || viewItem == project-session",
          "group": "sessionContext@1"
        },
        {
          "command": "starling.showSession",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == session-pin || viewItem == project-session",
          "group": "sessionContext@2"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == session-pin || viewItem == project-session",
          "group": "sessionContext@3"
        },
        {
          "command": "starling.copyProject",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == session-pin || viewItem == project-session",
          "group": "sessionContext@4"
        },
        {
          "command": "starling.copySessionId",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == session-pin || viewItem == project-session",
          "group": "sessionContext@5"
        },
        {
          "command": "starling.pin",
          "when": "viewItem == session-unpinned || viewItem == project-session",
          "group": "sessionContext@6"
        },
        {
          "command": "starling.pinToSpace",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == session-pin || viewItem == project-session",
          "group": "sessionContext@8"
        },
        {
          "command": "starling.removePin",
          "when": "viewItem == session-pinned || viewItem == session-pin",
          "group": "sessionContext@9"
        },
        {
          "command": "starling.deleteSession",
          "when": "viewItem == session-unpinned || viewItem == session-pinned || viewItem == session-pin || viewItem == project-session",
          "group": "sessionContext@10"
        },
        {
          "command": "starling.projectShow",
          "when": "viewItem == project",
          "group": "inline@1"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem == project",
          "group": "inline@2"
        },
        {
          "command": "starling.copyProject",
          "when": "viewItem == project",
          "group": "inline@3"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem == project",
          "group": "projectContext@1"
        },
        {
          "command": "starling.copyProject",
          "when": "viewItem == project",
          "group": "projectContext@2"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem =~ /session/",
          "group": "inline@2"
        },
        {
          "command": "starling.resume",
          "when": "viewItem == session-pin",
          "group": "catalogSession@1"
        },
        {
          "command": "starling.showSession",
          "when": "viewItem == session-pin",
          "group": "catalogSession@2"
        },
        {
          "command": "starling.openProject",
          "when": "viewItem == session-pin",
          "group": "catalogSession@3"
        },
        {
          "command": "starling.copyProject",
          "when": "viewItem == session-pin",
          "group": "catalogSession@4"
        },
        {
          "command": "starling.copySessionId",
          "when": "viewItem == session-pin",
          "group": "catalogSession@5"
        },
        {
          "command": "starling.removePin",
          "when": "viewItem == session-pin",
          "group": "catalogSession@6"
        },
        {
          "command": "starling.deleteSession",
          "when": "viewItem == session-pin",
          "group": "catalogSession@7"
        }
      ],
      "view/title": [
        {
          "command": "starling.refresh",
          "when": "view == starling-sessions || view == starling-spaces || view == starling-projects",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Starling",
      "properties": {
        "starling.cliPath": {
          "type": "string",
          "default": "starling",
          "description": "Path to the Starling CLI executable. Use an absolute path if the VS Code extension host cannot find starling on PATH."
        },
        "starling.cacheTtlSeconds": {
          "type": "number",
          "default": 30,
          "description": "How long CLI query results are cached in seconds. Set to 0 to disable cache.",
          "minimum": 0
        },
        "starling.projectSessionLimit": {
          "type": "number",
          "default": 30,
          "description": "Number of sessions shown per project node before requiring Load more. Set to 0 for all.",
          "minimum": 0
        },
        "starling.sessionTreeLimit": {
          "type": "number",
          "default": 50,
          "description": "Number of sessions loaded per batch in the Sessions view. Set to 0 to load all sessions.",
          "minimum": 0
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  },
  "extensionKind": [
    "workspace"
  ]
}
